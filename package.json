    "ai": "^6.0.42",
    "axios": "^1.15.0",
    "bullmq": "^5.69.3",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "escape-unicode": "^0.3.0",
    "google-trends-api": "^4.9.2",
    "ioredis": "^5.10.1",
    "jwt-decode": "^4.0.0",
    "md-to-pdf": "^5.2.5",
    "natural": "^8.1.1",
    "nodemailer": "^8.0.1",
    "partial-json": "^0.1.7",
    "pg": "^8.17.2",
    "prisma": "^7.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "unescape-unicode": "^0.3.0",
    "uuid": "^13.0.0",
