{
  "name": "perfume_gpt_ai_backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "setup": "ts-node -r tsconfig-paths/register setup.ts",
    "build": "nest build",
    "build:watch": "nest build --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev1": "npx kill-port 3000 && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "clean": "rimraf dist coverage",
    "seed": "ts-node -r tsconfig-paths/register src/infrastructure/domain/common/seed/run-seed.ts",
    "sync:prompts": "ts-node -r tsconfig-paths/register src/infrastructure/domain/common/seed/sync-prompts.ts",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "migration:create": "mikro-orm migration:create --name",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "db:check": "mikro-orm debug",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:all": "jest --config ./test/jest-unit.json && jest --config ./test/jest-integration.json --runInBand && jest --config ./test/jest-e2e.json",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --config ./test/jest-unit.json",
    "test:unit:watch": "jest --config ./test/jest-unit.json --watch",
    "test:unit:cov": "jest --config ./test/jest-unit.json --coverage",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "test:integration:watch": "jest --config ./test/jest-integration.json --runInBand --watch",
    "test:integration:cov": "jest --config ./test/jest-integration.json --runInBand --coverage",
    "test:integration:setup": "node test/integration/helpers/create-test-db.js",
    "test:search:v3": "ts-node scripts/run-search-v3-test.ts",
    "bullmq:delete-all-jobs": "ts-node scripts/deleteDataBullScript.ts",
    "find-deadcode": "ts-prune"
  },
