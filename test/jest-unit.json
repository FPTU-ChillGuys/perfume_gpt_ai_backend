{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/unit/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^generated/(.*)$": "<rootDir>/generated/$1",
    "^@toon-format/toon$": "<rootDir>/test/helpers/mocks/toon-format.mock.ts",
    "^natural$": "<rootDir>/test/helpers/mocks/natural.mock.ts"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(.pnpm|uuid)/)"
  ]
}
