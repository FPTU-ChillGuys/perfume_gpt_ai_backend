  Name             String             @default("N'", map: "DF__Suppliers__Name__13F1F5EB") @db.NVarChar(Max)
  ContactEmail     String             @default("N'", map: "DF__Suppliers__Conta__14E61A24") @db.NVarChar(Max)
  Phone            String             @default("N'", map: "DF__Suppliers__Phone__12FDD1B2") @db.NVarChar(Max)
  Address          String             @default("N'", map: "DF__Suppliers__Addre__15DA3E5D") @db.NVarChar(Max)
  ImportTickets    ImportTickets[]
  VariantSuppliers VariantSuppliers[]
}

model SystemPolicies {
  PolicyCode  String    @id(map: "PK_SystemPolicies") @db.NVarChar(100)
  Title       String    @db.NVarChar(255)
  HtmlContent String    @db.NVarChar(Max)
  CreatedAt   DateTime
  UpdatedAt   DateTime?
  UpdatedBy   String?   @db.NVarChar(Max)
}

model TemporaryMedia {
  Id               String       @id(map: "PK_TemporaryMedia") @db.UniqueIdentifier
  Url              String       @db.NVarChar(Max)
  AltText          String?      @db.NVarChar(Max)
  DisplayOrder     Int
  PublicId         String?      @db.NVarChar(Max)
  FileSize         BigInt?
  MimeType         String?      @db.NVarChar(Max)
  UploadedByUserId String?      @db.UniqueIdentifier
  ExpiresAt        DateTime
  CreatedAt        DateTime
  IsPrimary        Boolean      @default(dbgenerated("CONVERT([bit],(0))"), map: "DF__Temporary__IsPri__16CE6296")
  TargetEntityType String?      @db.NVarChar(Max)
  AspNetUsers      AspNetUsers? @relation(fields: [UploadedByUserId], references: [Id], onUpdate: NoAction, map: "FK_TemporaryMedia_AspNetUsers_UploadedByUserId")

  @@index([ExpiresAt], map: "IX_TemporaryMedia_ExpiresAt")
  @@index([UploadedByUserId], map: "IX_TemporaryMedia_UploadedByUserId")
}

model UserNotificationReads {
  UserId         String        @db.UniqueIdentifier
  NotificationId String        @db.UniqueIdentifier
  ReadAt         DateTime
  AspNetUsers    AspNetUsers   @relation(fields: [UserId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserNotificationReads_AspNetUsers_UserId")
  Notifications  Notifications @relation(fields: [NotificationId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserNotificationReads_Notifications_NotificationId")

  @@id([UserId, NotificationId], map: "PK_UserNotificationReads")
  @@index([NotificationId], map: "IX_UserNotificationReads_NotificationId")
}

model UserVouchers {
  Id              String       @id(map: "PK_UserVouchers") @db.UniqueIdentifier
  UserId          String?      @db.UniqueIdentifier
  VoucherId       String       @db.UniqueIdentifier
  CreatedAt       DateTime     @default(dbgenerated("0001-01-01T00:00:00.0000000"), map: "DF__UserVouch__Creat__17C286CF")
  UpdatedAt       DateTime?
  Status          String       @default("N'", map: "DF__UserVouch__Statu__18B6AB08") @db.NVarChar(Max)
  GuestIdentifier String?      @db.NVarChar(Max)
  OrderId         String?      @unique(map: "IX_UserVouchers_OrderId", where: raw("([OrderId] IS NOT NULL)")) @db.UniqueIdentifier
  AspNetUsers     AspNetUsers? @relation(fields: [UserId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserVouchers_AspNetUsers_UserId")
  Orders          Orders?      @relation(fields: [OrderId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_UserVouchers_Orders_OrderId")
  Vouchers        Vouchers     @relation(fields: [VoucherId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserVouchers_Vouchers_VoucherId")

  @@index([UserId], map: "IX_UserVouchers_UserId")
  @@index([VoucherId], map: "IX_UserVouchers_VoucherId")
}

model VariantSuppliers {
  Id                    String          @id(map: "PK_VariantSuppliers") @db.UniqueIdentifier
  ProductVariantId      String          @db.UniqueIdentifier
  SupplierId            Int
  NegotiatedPrice       Decimal         @db.Decimal(18, 2)
  IsPrimary             Boolean
  EstimatedLeadTimeDays Int
  CreatedAt             DateTime
  UpdatedAt             DateTime?
  ProductVariants       ProductVariants @relation(fields: [ProductVariantId], references: [Id], onUpdate: NoAction, map: "FK_VariantSuppliers_ProductVariants_ProductVariantId")
  Suppliers             Suppliers       @relation(fields: [SupplierId], references: [Id], onUpdate: NoAction, map: "FK_VariantSuppliers_Suppliers_SupplierId")

  @@unique([ProductVariantId, SupplierId], map: "IX_VariantSuppliers_ProductVariantId_SupplierId")
  @@index([SupplierId], map: "IX_VariantSuppliers_SupplierId")
}

model Vouchers {
  Id                  String                @id(map: "PK_Vouchers") @db.UniqueIdentifier
  Code                String                @unique(map: "IX_Vouchers_Code", where: raw("([IsDeleted]=(0))")) @db.NVarChar(450)
  DiscountValue       Decimal               @db.Decimal(18, 2)
  DiscountType        String                @default("N'", map: "DF__Vouchers__Discou__2057CCD0") @db.NVarChar(Max)
  RequiredPoints      Int                   @default(0, map: "DF__Vouchers__Requir__1E6F845E")
  MinOrderValue       Decimal               @default(0.0, map: "DF__Vouchers__MinOrd__1F63A897") @db.Decimal(18, 2)
  ExpiryDate          DateTime
  CreatedAt           DateTime              @default(dbgenerated("0001-01-01T00:00:00.0000000"), map: "DF__Vouchers__Create__1A9EF37A")
  DeletedAt           DateTime?
  IsDeleted           Boolean               @default(dbgenerated("CONVERT([bit],(0))"), map: "DF__Vouchers__IsDele__19AACF41")
  UpdatedAt           DateTime?
  IsPublic            Boolean               @default(dbgenerated("CONVERT([bit],(0))"), map: "DF__Vouchers__IsPubl__1C873BEC")
  RemainingQuantity   Int?
  TotalQuantity       Int?
  ApplyType           String                @default("N'", map: "DF__Vouchers__ApplyT__1D7B6025") @db.NVarChar(Max)
  CampaignId          String?               @db.UniqueIdentifier
  TargetItemType      String?               @db.NVarChar(Max)
  MaxDiscountAmount   Decimal?              @db.Decimal(18, 2)
  MaxUsagePerUser     Int?
  IsMemberOnly        Boolean               @default(dbgenerated("CONVERT([bit],(0))"), map: "DF__Vouchers__IsMemb__1B9317B3")
  LoyaltyTransactions LoyaltyTransactions[]
  UserVouchers        UserVouchers[]
  Campaigns           Campaigns?            @relation(fields: [CampaignId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Vouchers_Campaigns_CampaignId")

  @@index([CampaignId], map: "IX_Vouchers_CampaignId")
}
