# Server Port
PORT=3000

# PostgreSQL (MikroORM) - These values are used in host-config.mjs but still need to be defined here for consistency
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Configuration (must match .NET backend)
JWT_ISSUER=https://localhost:7011
JWT_AUDIENCE=https://localhost:7011

# Base URL (.NET Backend)
BASE_URL=https://localhost:7011/api

# Frontend URL (for email links and product redirects)
FRONTEND_URL=http://localhost:5173

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Redis (BullMQ job queue + Cache store)
REDIS_HOST=localhost
REDIS_PORT=6379

# SQL Server - Prisma connection (adapter for .NET DB)
# Note: Replace with your actual SQL Server connection details
SQL_SERVER_DATABASE_URL="sqlserver://localhost:1433;database=PerfumeDb;user=sa;password=your_mssql_password;encrypt=false;trustServerCertificate=true"
SQL_SERVER_DATABASE_SERVER=localhost
SQL_SERVER_DATABASE_PORT=1433
SQL_SERVER_DATABASE_USER=sa
SQL_SERVER_DATABASE_PASSWORD=your_mssql_password
SQL_SERVER_DATABASE_NAME=PerfumeDb

# Cache Configuration
CACHE_TTL=60000
CACHE_LRU_SIZE=5000

# Google Gmail - NodeMailer SMTP
GOOGLE_EMAIL=your_gmail@gmail.com
GOOGLE_APP_PASSWORD=your_app_password

# TLS Configuration (for development)
NODE_TLS_REJECT_UNAUTHORIZED=0

