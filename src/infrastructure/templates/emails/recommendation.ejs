<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body
    style="margin:0;padding:0;background:#f8f9fa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8f9fa;">
        <tr>
            <td align="center" style="padding:40px 0;">

                <table width="600" cellpadding="0" cellspacing="0"
                    style="background:#ffffff;border-radius:8px;overflow:hidden;">

                    <!-- HEADER -->
                    <tr>
                        <td style="background:#e91e63;padding:30px;text-align:center;">
                            <h1 style="color:#ffffff;margin:0;font-size:30px;font-weight:700;">
                                🌸 PerfumeGPT
                            </h1>

                            <p style="color:#ffd6e7;margin:8px 0 0 0;font-size:14px;">
                                Your Personal Fragrance AI Advisor
                            </p>
                        </td>
                    </tr>


                    <!-- BODY -->
                    <tr>
                        <td style="padding:40px;">

                            <p style="font-size:16px;color:#333;margin:0 0 25px 0;">
                                Xin chào <strong>
                                    <%= userName %>
                                </strong>,
                            </p>


                            <!-- AI MESSAGE -->
                            <table width="100%" cellpadding="0" cellspacing="0"
                                style="background:#f5f5f5;border-left:4px solid #e91e63;margin-bottom:30px;">
                                <tr>
                                    <td style="padding:20px;">

                                        <h2 style="color:#c2185b;font-size:18px;margin:0 0 15px 0;">
                                            <%= heading %>
                                        </h2>

                                        <div style="color:#555;font-size:15px;line-height:1.6;">
                                            <%- message %>
                                        </div>

                                    </td>
                                </tr>
                            </table>



                            <!-- PRODUCTS -->
                            <% if (products && products.length> 0) { %>

                                <h3 style="font-size:16px;color:#333;margin:0 0 20px 0;">
                                    ✨ Sản phẩm được đề xuất
                                </h3>

                                <% products.forEach((product)=> { %>

                                    <table width="100%" cellpadding="0" cellspacing="0"
                                        style="border:1px solid #e0e0e0;border-radius:8px;margin-bottom:20px;">

                                        <tr>
                                            <td style="padding:15px;">

                                                <!-- PRODUCT HEADER -->
                                                <p style="margin:0;font-size:16px;font-weight:700;color:#333;">
                                                    <%= product.name %>
                                                </p>

                                                <p style="margin:4px 0 15px 0;font-size:12px;color:#888;">
                                                    <%= product.brandName %> • <%= product.categoryName %>
                                                </p>


                                                <!-- PRICE + BUTTON -->
                                                <table width="100%" cellpadding="0" cellspacing="0">
                                                    <tr>

                                                        <td align="left" valign="top">

                                                            <% if (product.variants && product.variants.length> 0) { %>

                                                                <p
                                                                    style="margin:0;font-size:18px;font-weight:700;color:#e91e63;">
                                                                    <%= product.variants[0].basePrice.toLocaleString('vi-VN')
                                                                        %>₫
                                                                </p>

                                                                <p style="margin:3px 0 0 0;font-size:11px;color:#999;">
                                                                    từ <%= product.variants[0].volumeMl %>ml
                                                                </p>

                                                                <% } %>

                                                        </td>


                                                        <td align="right" valign="middle">

                                                            <a href="<%= frontendUrl %>/products/<%= product.id %>"
                                                                style="background:#e91e63;color:#ffffff;padding:10px 18px;text-decoration:none;border-radius:4px;font-size:14px;font-weight:600;display:inline-block;">
                                                                Mua ngay →
                                                            </a>

                                                        </td>

                                                    </tr>
                                                </table>



                                                <!-- DESCRIPTION -->
                                                <p
                                                    style="font-size:13px;color:#666;margin:15px 0 10px 0;line-height:1.6;">
                                                    <%= product.description %>
                                                </p>



                                                <!-- VARIANTS -->
                                                <% if (product.variants && product.variants.length> 0) { %>

                                                    <table width="100%" cellpadding="6" cellspacing="0"
                                                        style="border-top:1px solid #f0f0f0;margin-top:10px;">

                                                        <tr>
                                                            <td colspan="2"
                                                                style="font-size:12px;color:#999;font-weight:600;padding-top:10px;">
                                                                💰 Các phiên bản
                                                            </td>
                                                        </tr>

                                                        <% product.variants.forEach((variant)=> { %>

                                                            <tr>

                                                                <td style="font-size:12px;color:#666;">
                                                                    <strong>
                                                                        <%= variant.volumeMl %>ml
                                                                    </strong>
                                                                    (<%= variant.type %>) - <%=
                                                                            variant.concentrationName %>
                                                                </td>

                                                                <td align="right"
                                                                    style="font-size:12px;color:#e91e63;font-weight:700;">
                                                                    <%= variant.basePrice.toLocaleString('vi-VN') %>₫
                                                                </td>

                                                            </tr>

                                                            <% }); %>

                                                    </table>

                                                    <% } %>


                                            </td>
                                        </tr>
                                    </table>

                                    <% }) %>

                                        <% } %>



                                            <!-- CTA -->
                                            <table width="100%" cellpadding="0" cellspacing="0">
                                                <tr>
                                                    <td align="center" style="padding:20px 0;">

                                                        <a href="<%= frontendUrl %>"
                                                            style="background:#e91e63;color:#ffffff;padding:12px 28px;text-decoration:none;border-radius:4px;font-weight:600;font-size:15px;display:inline-block;">
                                                            Khám phá thêm →
                                                        </a>

                                                    </td>
                                                </tr>
                                            </table>



                                            <!-- TIP -->
                                            <p
                                                style="font-size:13px;color:#999;margin-top:30px;border-top:1px solid #eee;padding-top:20px;">
                                                💡 <strong>Mẹo:</strong> AI của chúng tôi học hỏi từ sở thích của bạn.
                                                Càng tương tác nhiều, khuyến nghị sẽ càng chính xác.
                                            </p>


                        </td>
                    </tr>



                    <!-- FOOTER -->
                    <tr>
                        <td style="background:#f8f9fa;padding:20px;text-align:center;border-top:1px solid #e0e0e0;">

                            <p style="font-size:12px;color:#999;margin:0 0 6px 0;">
                                © 2026 PerfumeGPT
                            </p>

                            <p style="font-size:11px;color:#bbb;margin:0;">
                                Bạn nhận email này vì bạn là thành viên VIP của PerfumeGPT
                            </p>

                        </td>
                    </tr>


                </table>

            </td>
        </tr>
    </table>

</body>

</html>